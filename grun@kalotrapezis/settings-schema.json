{
    "head-open": {
        "type": "header",
        "description": "Opening grun"
    },
    "hotkey": {
        "type": "keybinding",
        "default": "<Control><Alt>a",
        "description": "Global shortcut to open grun"
    },
    "max-results": {
        "type": "spinbutton",
        "default": 10,
        "min": 4,
        "max": 30,
        "step": 1,
